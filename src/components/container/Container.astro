---
import "./Container.css";

interface Props {
  class?: string;
  variant?: "default" | "minimal";
}

const { variant = "default" } = Astro.props;
const className = ["container", `container--${variant}`, Astro.props.class]
  .filter(Boolean)
  .join(" ");
---

<article class={className}>
  <slot />
</article>
