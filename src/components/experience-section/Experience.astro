---
import { translations, type Locale } from "../../i18n/translations";
import TitleSection from "../title-section/TitleSection.astro";
import "./Experience.css";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const copy = translations[lang].experience;
---

<section id="experience" class="section experience" aria-labelledby="experience-title">
  <div class="experience__intro">
    <TitleSection id="experience-title" title={copy.title} />
  </div>

  <div class="experience__list">
    {copy.items.map((item) => (
      <article class="experience__item">
        <p class="experience__period">{item.period}</p>

        <div class="experience__heading">
          <h3 class="experience__company">{item.company}</h3>
          <p class="experience__role">{item.role}</p>
        </div>

        <p class="experience__description">{item.description}</p>
      </article>
    ))}
  </div>
</section>
