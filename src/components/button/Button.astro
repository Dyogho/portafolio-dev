---
import "./Button.css";

type Props = {
  href?: string;
  label?: string;
  class?: string;
};

const { href, label = "Button" } = Astro.props;
const className = ["button", Astro.props.class].filter(Boolean).join(" ");
---

{href ? <a class={className} href={href}>{label}</a> : <button class={className}>{label}</button>}
