---
import { translations, type Locale } from "../../i18n/translations";
import StackCard from "../stack-card/StackCard.astro";
import TitleSection from "../title-section/TitleSection.astro";
import "./AboutMe.css";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const copy = translations[lang].about;

const stack = [
  { title: "TypeScript", icon: "/icons/typescript.svg" },
  { title: "React", icon: "/icons/react.svg" },
  { title: "Next.js", icon: "/icons/nextjs.svg" },
  { title: "Angular", icon: "/icons/angular.svg" },
  { title: "Astro", icon: "/icons/astro.svg" },
  { title: "Tailwind CSS", icon: "/icons/tailwindcss.svg" },
  { title: "Docker", icon: "/icons/docker.svg" },
  { title: "Git", icon: "/icons/git.svg" },
  { title: "SEO", icon: "/icons/seo.svg" },
  { title: "Accessibility", icon: "/icons/accessibility.svg" },
  { title: "Performance", icon: "/icons/performance.svg" },
  { title: "Scrum", icon: "/icons/scrum.svg" },
];
---

<section id="about" class="section about" aria-labelledby="about-title">
  <div class="about__intro">
    <TitleSection id="about-title" title={copy.title} />
  </div>

  <div class="about__content">
    <div class="about__copy">
      {copy.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <div class="about__stack" aria-label={copy.stackLabel}>
      {stack.map((item) => (
        <StackCard class="about__stack-card" title={item.title} icon={item.icon} />
      ))}
    </div>
  </div>
</section>
