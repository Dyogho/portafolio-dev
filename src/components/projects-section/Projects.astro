---
import Button from "../button/Button.astro";
import Container from "../container/Container.astro";
import Icon from "../icon/Icon.astro";
import SectionHeading from "../section-heading/SectionHeading.astro";
import "./Projects.css";

const projects = [
  {
    title: "SaaS Landing Page",
    description: "Página comercial enfocada en conversión, velocidad de carga y una narrativa clara del producto.",
    href: "#",
    meta: "Web design",
    tags: ["Astro", "CSS", "SEO"],
  },
  {
    title: "Design System",
    description: "Biblioteca de componentes reutilizables con documentación visual y criterios de accesibilidad.",
    href: "#",
    meta: "UI engineering",
    tags: ["Storybook", "Tokens", "A11y"],
  },
  {
    title: "Portfolio v1",
    description: "Experiencia personal minimalista, responsive y optimizada para presentar proyectos técnicos.",
    href: "#",
    meta: "Personal brand",
    tags: ["Astro", "TypeScript", "CSS"],
  },
];
---

<section id="projects" class="section page-grid projects" aria-labelledby="projects-title">
  <div class="projects__header">
    <SectionHeading
      eyebrow="Selected work"
      title="Projects"
      description="Una selección de trabajos donde combino interfaz, código y criterio de producto."
    />
    <Button href="https://github.com" label="GitHub" />
  </div>

  <div class="projects__grid">
    {projects.map((project) => (
      <Container class="project-card">
        <p class="project-card__meta">{project.meta}</p>
        <h3>{project.title}</h3>
        <p>{project.description}</p>
        <ul class="project-card__tags" aria-label="Tecnologías">
          {project.tags.map((tag) => <li class="project-card__tag">{tag}</li>)}
        </ul>
        <a class="project-card__link" href={project.href}>
          View project <Icon name="arrow" size={18} />
        </a>
      </Container>
    ))}
  </div>
</section>
