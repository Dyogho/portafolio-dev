---
import { locales, translations, type Locale } from "../../i18n/translations";
import "./Header.css";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const copy = translations[lang].header;
const navItems = copy.nav;
---

<header class="site-header site-header--hero-visible">
  <a class="site-header__logo" href={locales[lang].path} aria-label={copy.home}>
    <span class="site-header__logo-mark" aria-hidden="true"></span>
  </a>

  <nav class="site-header__language" aria-label={copy.languageLabel} data-language-switch>
    {(Object.keys(locales) as Locale[]).map((locale) => (
      <a
        class:list={["site-header__language-link", locale === lang && "site-header__language-link--active"]}
        href={locales[locale].path}
        lang={locale}
        aria-current={locale === lang ? "page" : undefined}
        aria-label={locales[locale].languageName}
      >
        {locales[locale].label}
      </a>
    ))}
  </nav>

  <nav class="site-header__nav" aria-label={copy.primaryNav}>
    {navItems.map(({ href, label }) => (
      <a class="site-header__nav-link" href={href}>{label}</a>
    ))}
  </nav>
</header>

<script>
  const header = document.querySelector(".site-header");
  const hero = document.getElementById("hero");

  if (header && hero && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        header.classList.toggle("site-header--hero-visible", entry.isIntersecting);
      },
      { threshold: 0.35 },
    );

    observer.observe(hero);
  }
</script>
