---
import "./Icon.css";

type IconName = "arrow" | "github" | "linkedin" | "youtube";

type Props = {
  /** Built-in icon name. */
  name?: IconName;
  /** Remote image/SVG URL. */
  url?: string;
  /** Local path, usually from public. Example: /icons/logo.svg */
  local?: string;
  /** Generic source path for remote or local assets. */
  src?: string;
  /** Trusted inline SVG markup as string. */
  svg?: string;
  label?: string;
  size?: number | string;
  class?: string;
};

const {
  name = "arrow",
  url,
  local,
  src,
  svg,
  label,
  size = 24,
} = Astro.props;

const source = url ?? local ?? src;
const className = ["icon", Astro.props.class].filter(Boolean).join(" ");
const cssSize = typeof size === "number" ? `${size}px` : size;
const isHidden = label ? undefined : "true";
---

<span class={className} style={`--icon-size: ${cssSize}`} aria-label={label} aria-hidden={isHidden}>
  {svg ? (
    <span class="icon__svg" set:html={svg} />
  ) : source ? (
    <img class="icon__image" src={source} alt="" decoding="async" />
  ) : (
    <svg class="icon__svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      {name === "github" ? (
        <path d="M12 2a10 10 0 0 0-3 19c.5.1.7-.2.7-.5v-2c-3 .7-3.7-1.2-3.7-1.2-.5-1.2-1.1-1.5-1.1-1.5-.9-.6.1-.6.1-.6 1 0 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 3 .8.1-.7.4-1.1.7-1.3-2.4-.3-5-1.2-5-5.4 0-1.2.4-2.2 1.1-3-.1-.3-.5-1.5.1-3 0 0 .9-.3 3.1 1.1a10.7 10.7 0 0 1 5.6 0c2.1-1.4 3.1-1.1 3.1-1.1.6 1.5.2 2.7.1 3 .7.8 1.1 1.8 1.1 3 0 4.2-2.6 5.1-5 5.4.4.3.7 1 .7 2v2.7c0 .3.2.6.8.5A10 10 0 0 0 12 2Z" />
      ) : name === "linkedin" ? (
        <path d="M6.5 10v8m0-11.5v.01M10 18v-8h3.8c2.4 0 3.7 1.4 3.7 4.2V18m-4-4.2V18M4 4h16v16H4z" />
      ) : name === "youtube" ? (
        <path d="M10 9.5 15 12l-5 2.5v-5Z" /><path d="M21 12c0 2.1-.2 3.4-.5 4.1-.2.7-.8 1.2-1.5 1.4-1.3.4-7 .4-7 .4s-5.7 0-7-.4a2.2 2.2 0 0 1-1.5-1.4C3.2 15.4 3 14.1 3 12s.2-3.4.5-4.1c.2-.7.8-1.2 1.5-1.4 1.3-.4 7-.4 7-.4s5.7 0 7 .4c.7.2 1.3.7 1.5 1.4.3.7.5 2 .5 4.1Z" />
      ) : (
        <path d="M5 12h14m-6-6 6 6-6 6" />
      )}
    </svg>
  )}
</span>
