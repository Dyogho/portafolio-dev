---
import "./TitleSection.css";

interface Props {
  title: string;
  class?: string;
  id?: string;
}

const { title, id } = Astro.props;
const className = ["title-section", Astro.props.class].filter(Boolean).join(" ");
---

<header class={className}>
  <h2 id={id} class="title-section__title">{title}</h2>
</header>
