---
import { Image } from "astro:assets";
import portrait from "../../assets/portrait.jpeg";
import { translations, type Locale } from "../../i18n/translations";
import "./Hero.css";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const copy = translations[lang].hero;
const [role, year] = copy.sidebarItems;
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="hero__wrapper">
    <aside class="hero__sidebar" aria-hidden="true">
      <span>{role}</span>
      <span class="hero__sidebar-line"></span>
      <span>{year}</span>
    </aside>

    <div class="hero__content">
      <dl class="hero__metrics" aria-label={copy.metricsLabel}>
        {copy.metrics.map(({ value, label }) => (
          <div class="hero__metric">
            <dt class="hero__number">{value}</dt>
            <dd class="hero__label">{label}</dd>
          </div>
        ))}
      </dl>

      <div class="hero__body">
        <h1 id="hero-title" class="hero__title">{copy.title}</h1>
        <p class="hero__subtitle">{copy.subtitle}</p>
      </div>

      <a class="hero__scroll" href="#projects">{copy.scroll}</a>
    </div>

    <figure class="hero__media" aria-label={copy.portraitLabel}>
      <Image
        class="hero__image"
        src={portrait}
        alt={copy.portraitAlt}
        widths={[480, 720, 960]}
        sizes="(max-width: 1024px) 0px, 45vw"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    </figure>
  </div>
</section>
