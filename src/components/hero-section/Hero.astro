---
import "./Hero.css";

const sidebarItems = ["Frontend Developer", "2026"];

const metrics = [
  { value: "+200", label: "Project completed" },
  { value: "+50", label: "Startup raised" },
];
---

<section id="hero" class="hero" aria-labelledby="hero-title">
  <div class="hero__wrapper">
    <aside class="hero__sidebar" aria-hidden="true">
      <span>{sidebarItems[0]}</span>
      <span class="hero__sidebar-line"></span>
      <span>{sidebarItems[1]}</span>
    </aside>

    <div class="hero__content">
      <dl class="hero__metrics" aria-label="Portfolio metrics">
        {metrics.map(({ value, label }) => (
          <div class="hero__metric">
            <dt class="hero__number">{value}</dt>
            <dd class="hero__label">{label}</dd>
          </div>
        ))}
      </dl>

      <div class="hero__body">
        <h1 id="hero-title" class="hero__title">Hello</h1>
        <p class="hero__subtitle">— It's Dego a code wizard</p>
      </div>

      <a class="hero__scroll" href="#projects">Scroll down ↓</a>
    </div>

    <figure class="hero__media" aria-label="Portrait of Dego">
      <img class="hero__image" src="/image.jpeg" alt="Dego" />
    </figure>
  </div>
</section>
